# Required: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Public URL where the app is hosted
BETTER_AUTH_URL=http://localhost:4321

# Unsplash Access Key for cover photo search
# Create an app at https://unsplash.com/documentation
UNSPLASH_ACCESS_KEY=

# OpenRouter API key (required for recipe import + chat)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=google/gemini-3-flash-preview
OPENROUTER_FALLBACK_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Prepped

# Optional: scrape.do fallback for blocked recipe websites
# Get a token at https://scrape.do
SCRAPE_DO_TOKEN=
SCRAPE_DO_BASE_URL=http://api.scrape.do/
SCRAPE_DO_GEO_CODE=NL

# Optional: Scaleway S3 backup target for database snapshots and uploaded images
SCW_REGION=fr-par
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET=bentbackup
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
S3_BACKUP_PREFIX=recepten.bentjes.nl
BACKUP_TIME=03:00
BACKUP_RUN_ON_START=false
TZ=Europe/Amsterdam

# Optional: require an invite code to register
# Leave empty for open registration
INVITE_CODE=

# Measurement system: metric (default) or imperial
MEASUREMENT_SYSTEM=metric

# UI language: en (default) or nl
PUBLIC_UI_LOCALE=en

# Auth mode: "password" (email+password via Better Auth) or "simple" (name-only)
AUTH_MODE=password
