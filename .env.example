# Required: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=

# Public URL where the app is hosted
BETTER_AUTH_URL=http://localhost:4321

# Unsplash Access Key for cover photo search
# Create an app at https://unsplash.com/documentation
UNSPLASH_ACCESS_KEY=

# OpenRouter API key (required for recipe import + chat)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_PRIMARY_MODEL=google/gemini-3-flash-preview
OPENROUTER_FALLBACK_MODEL=openai/gpt-5-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Prepped

# Optional: Cloudflare Browser Run fallback for blocked recipe websites
# Requires a token with Browser Rendering - Edit permission
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Minimum delay between Browser Run Quick Actions in milliseconds.
# Default 10000 matches the Workers Free limit of 1 request every 10 seconds.
CLOUDFLARE_BROWSER_RUN_MIN_INTERVAL_MS=10000

# Optional: Scaleway S3 backup target for database snapshots and uploaded images
SCW_REGION=fr-par
SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_BUCKET=bentbackup
SCW_ENDPOINT=https://s3.fr-par.scw.cloud
S3_BACKUP_PREFIX=recepten.bentjes.nl
BACKUP_TIME=03:00
BACKUP_RUN_ON_START=false
TZ=Europe/Amsterdam

# Optional: override where `/app/data` is mounted from.
# Leave unset to use the default Docker named volume `prepped-data`.
# Set this to a host path in production if you want direct bind-mounted data,
# for example `/srv/recepten-bentjes-nl/data`.
PREPPED_DATA_MOUNT=

# Optional: pin the Docker volume name used for /app/data.
# Useful when you stay on named volumes and want a stable production volume
# even if the compose project/app name changes.
PREPPED_DATA_VOLUME=prepped-data
PREPPED_DATA_EXTERNAL=false

# Optional: require an invite code to register
# Leave empty for open registration
INVITE_CODE=

# Measurement system: metric (default) or imperial
MEASUREMENT_SYSTEM=metric

# UI language: en (default) or nl
PUBLIC_UI_LOCALE=en

# Auth mode: "password" (email+password via Better Auth) or "simple" (name-only)
AUTH_MODE=password
