---
import Layout from "../../../../layouts/Layout.astro";
import ServingsScaler from "../../../../islands/ServingsScaler";
import RecipeChat from "../../../../islands/RecipeChat";
import CookLogForm from "../../../../islands/CookLogForm";
import FavoriteButton from "../../../../islands/FavoriteButton";
import AddToShoppingListButton from "../../../../islands/AddToShoppingListButton";
import SaveRecipeDialog from "../../../../islands/SaveRecipeDialog";
import CopyRecipeDialog from "../../../../islands/CopyRecipeDialog";
import { db } from "../../../../lib/db";
import { recipes, recipeTags, tags, recipeCollections, collections, users, favorites, cookLogs } from "../../../../lib/schema";
import { eq, and, asc, count } from "drizzle-orm";
import { t, formatDate } from "../../../../lib/i18n";

const { id: userId, slug } = Astro.params;

// Verify user exists
const profileUser = db.select().from(users).where(eq(users.id, userId!)).get();
if (!profileUser) {
  return Astro.redirect("/users");
}

// Find recipe by slug + owner
const recipe = db
  .select()
  .from(recipes)
  .where(and(eq(recipes.slug, slug!), eq(recipes.createdBy, userId!)))
  .get();
if (!recipe) {
  return Astro.redirect(`/users/${userId}`);
}

// If this is the user's own recipe, redirect to the owner view
if (Astro.locals.user?.id === userId) {
  return Astro.redirect(`/recipes/${slug}`);
}

// Get tags for this recipe
const recipeTags_ = db
  .select({ name: tags.name, slug: tags.slug })
  .from(recipeTags)
  .innerJoin(tags, eq(recipeTags.tagId, tags.id))
  .where(eq(recipeTags.recipeId, recipe.id))
  .all();

// Get collections for this recipe
const recipeCollections_ = db
  .select({ name: collections.name, slug: collections.slug })
  .from(recipeCollections)
  .innerJoin(collections, eq(recipeCollections.collectionId, collections.id))
  .where(eq(recipeCollections.recipeId, recipe.id))
  .all();

// Check if favorited by current user
const currentUser = Astro.locals.user;
const isFavorited = currentUser
  ? !!db
      .select()
      .from(favorites)
      .where(and(eq(favorites.userId, currentUser.id), eq(favorites.recipeId, recipe.id)))
      .get()
  : false;

// Get user's own collections for copy dialog, sorted by recipe count
const userCollectionsRaw = currentUser
  ? db
      .select({ id: collections.id, name: collections.name })
      .from(collections)
      .where(eq(collections.createdBy, currentUser.id))
      .all()
  : [];

const collectionCounts = db
  .select({ collectionId: recipeCollections.collectionId, count: count() })
  .from(recipeCollections)
  .groupBy(recipeCollections.collectionId)
  .all();
const colCountsMap = new Map(collectionCounts.map((c) => [c.collectionId, c.count]));

userCollectionsRaw.sort((a, b) => (colCountsMap.get(b.id) || 0) - (colCountsMap.get(a.id) || 0));
const userCollections = userCollectionsRaw.map((c) => ({
  ...c,
  recipeCount: colCountsMap.get(c.id) || 0,
}));

// Get cook logs for this recipe (from all users)
const logs = db
  .select({
    id: cookLogs.id,
    photoUrl: cookLogs.photoUrl,
    notes: cookLogs.notes,
    rating: cookLogs.rating,
    cookedAt: cookLogs.cookedAt,
    authorName: users.name,
  })
  .from(cookLogs)
  .leftJoin(users, eq(cookLogs.createdBy, users.id))
  .where(eq(cookLogs.recipeId, recipe.id))
  .orderBy(cookLogs.cookedAt)
  .all();

// Check if current user already forked this recipe
const forkedRecipe = currentUser
  ? db
      .select({ id: recipes.id, slug: recipes.slug })
      .from(recipes)
      .where(and(eq(recipes.copiedFrom, recipe.id), eq(recipes.createdBy, currentUser.id)))
      .get()
  : null;
const alreadyForked = !!forkedRecipe;
const forkSlug = forkedRecipe?.slug;

// Check if recipe is already saved to any of user's collections
const savedCollectionIds = currentUser
  ? db
      .select({ id: collections.id })
      .from(recipeCollections)
      .innerJoin(collections, eq(recipeCollections.collectionId, collections.id))
      .where(and(eq(recipeCollections.recipeId, recipe.id), eq(collections.createdBy, currentUser.id)))
      .all()
      .map((c) => c.id)
  : [];

const ingredients = recipe.ingredients as { amount: string; unit: string; name: string; group?: string }[];
const steps = recipe.steps as { order: number; instruction: string; duration?: number }[];

// Extract YouTube video ID
function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtu\.be\/|youtube\.com\/(?:embed\/|v\/|watch\?v=|shorts\/))([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}
const youtubeId = recipe.videoUrl ? getYouTubeId(recipe.videoUrl) : null;

// Extract Instagram embed path
function getInstagramEmbedPath(url: string): string | null {
  const match = url.match(/instagram\.com\/((?:p|reel)\/[A-Za-z0-9_-]+)/);
  return match ? match[1] : null;
}
const instagramUrl = recipe.videoUrl || recipe.sourceUrl || "";
const instagramEmbedPath = getInstagramEmbedPath(instagramUrl);

const totalTime = (recipe.prepTime || 0) + (recipe.cookTime || 0);
---

<Layout title={recipe.title} description={recipe.description || undefined}>
  <article class="max-w-4xl mx-auto">

    {/* ===== Hero image ===== */}
    {recipe.imageUrl && (
      <div class="no-print -mx-4 sm:-mx-6 md:mx-0 md:rounded-2xl overflow-hidden mb-10 animate-fade-in relative">
        <div class="aspect-[16/9] md:aspect-[2/1]">
          <img
            src={recipe.imageUrl.startsWith("/") ? `/api/uploads${recipe.imageUrl}` : recipe.imageUrl}
            alt={recipe.title}
            class="w-full h-full object-cover"
          />
        </div>
        {/* Warm gradient overlay */}
        <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-background/40 to-transparent pointer-events-none" />
      </div>
    )}

    {/* ===== Title + description ===== */}
    <div class="mb-8 animate-fade-up">
      <h1 class="font-serif text-4xl md:text-5xl tracking-tight text-foreground leading-[1.08] text-balance">
        {recipe.title}
      </h1>
      {recipe.description && (
        <p class="text-lg text-muted-foreground/70 mt-4 max-w-2xl leading-relaxed">
          {recipe.description}
        </p>
      )}
    </div>

    {/* ===== Meta bar ===== */}
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:gap-x-6 sm:gap-y-3 mb-8 sm:mb-10 animate-fade-up" style="animation-delay: 120ms;">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs sm:text-sm text-muted-foreground/60 min-w-0">
        <a href={`/users/${userId}`} class="inline-flex items-center gap-1.5 hover:text-primary transition-colors max-w-full">
          <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 text-[10px] font-semibold text-primary shrink-0">
            {profileUser.name.charAt(0).toUpperCase()}
          </span>
          <span class="truncate font-medium text-foreground/70 group-hover:text-primary">{profileUser.name}</span>
        </a>
        {recipe.prepTime && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
            </svg>
            {t("recipe.prepTime")} {recipe.prepTime}{t("recipe.minutes")}
          </span>
        )}
        {recipe.cookTime && (
          <span class="inline-flex items-center gap-1.5">
            <svg class="w-3.5 h-3.5 text-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
            </svg>
            {t("recipe.cookTime")} {recipe.cookTime}{t("recipe.minutes")}
          </span>
        )}
        {recipe.difficulty && (
          <span class="inline-flex items-center gap-1.5 capitalize">
            <span class:list={[
              "w-2 h-2 rounded-full ring-2",
              recipe.difficulty === "easy" ? "bg-emerald-400 ring-emerald-400/20" :
              recipe.difficulty === "medium" ? "bg-amber-400 ring-amber-400/20" : "bg-rose-400 ring-rose-400/20"
            ]} />
            {t(`recipe.${recipe.difficulty}` as any)}
          </span>
        )}
      </div>

      {/* Actions for viewers */}
      <div class="flex flex-wrap items-center gap-1.5 shrink-0 sm:ml-auto">
        {alreadyForked && forkSlug && (
          <a
            href={`/recipes/${forkSlug}`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/15 hover:bg-primary/15 transition-colors"
          >
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {t("recipe.alreadyForked")}
          </a>
        )}
        {currentUser && (
          <>
            <SaveRecipeDialog
              recipeId={recipe.id}
              collections={userCollections}
              savedCollectionIds={savedCollectionIds}
              client:load
            />
            {!alreadyForked && (
              <CopyRecipeDialog
                recipeId={recipe.id}
                collections={userCollections}
                client:load
              />
            )}
            <FavoriteButton recipeId={recipe.id} initialFavorited={isFavorited} client:load />
          </>
        )}
        <button
          id="share-recipe"
          class="md:hidden inline-flex items-center justify-center h-7 w-7 rounded-full text-xs font-medium bg-secondary/60 text-muted-foreground border border-border/30 hover:bg-secondary hover:text-foreground transition-colors"
          aria-label={t("recipe.share")}
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8" /><polyline points="16 6 12 2 8 6" /><line x1="12" x2="12" y1="2" y2="15" />
          </svg>
        </button>
        <button
          class="inline-flex items-center justify-center h-7 w-7 rounded-full text-xs font-medium bg-secondary/60 text-muted-foreground border border-border/30 hover:bg-secondary hover:text-foreground transition-colors"
          aria-label={t("recipe.print")}
          onclick="window.print()"
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 6 2 18 2 18 9" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><rect width="12" height="8" x="6" y="14" />
          </svg>
        </button>
        {currentUser && (
          <AddToShoppingListButton recipeId={recipe.id} defaultServings={recipe.servings || 4} client:load />
        )}
      </div>
    </div>

    {/* Warm separator */}
    <div class="separator-warm mb-8 sm:mb-10 animate-fade-up" style="animation-delay: 140ms;" />

    {/* Collections + Tags */}
    {(recipeCollections_.length > 0 || recipeTags_.length > 0) && (
      <div class="flex flex-wrap gap-2 mb-10 animate-fade-up" style="animation-delay: 160ms;">
        {recipeCollections_.map((col) => (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-primary/10 text-primary border border-primary/15">
            {col.name}
          </span>
        ))}
        {recipeTags_.map((tag) => (
          <span class="px-3 py-1 rounded-full text-xs font-medium bg-secondary text-secondary-foreground border border-border/20">
            {tag.name}
          </span>
        ))}
      </div>
    )}

    {/* ===== Main content: Ingredients + Steps ===== */}
    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_minmax(0,2fr)] gap-10 lg:gap-14 animate-fade-up" style="animation-delay: 200ms;">
      <div>
        <h2 class="font-serif text-2xl tracking-tight mb-5 flex items-center gap-3">
          {t("recipe.ingredients")}
          <span class="flex-1 h-px bg-gradient-to-r from-border/40 to-transparent" />
        </h2>
        <div class="rounded-2xl bg-card/60 border border-border/25 p-5 backdrop-blur-sm">
          <ServingsScaler
            defaultServings={recipe.servings || 4}
            ingredients={ingredients}
            client:visible
          />
          <div class="mt-4 pt-4 border-t border-border/15">
            <AddToShoppingListButton recipeId={recipe.id} defaultServings={recipe.servings || 4} showLabel client:load />
          </div>
        </div>
      </div>

      <div>
        <h2 class="font-serif text-2xl tracking-tight mb-5 flex items-center gap-3">
          {t("recipe.steps")}
          <span class="flex-1 h-px bg-gradient-to-r from-border/40 to-transparent" />
        </h2>
        <ol class="space-y-8">
          {steps.map((step, si) => (
            <li class="flex gap-5 group/step">
              <span class="flex items-center justify-center h-9 w-9 rounded-full bg-primary/[0.08] text-primary text-sm font-semibold shrink-0 border border-primary/15 transition-all duration-300 group-hover/step:bg-primary group-hover/step:text-primary-foreground group-hover/step:shadow-lg group-hover/step:shadow-primary/15 group-hover/step:scale-105">
                {step.order}
              </span>
              <div class="flex-1 pt-1.5">
                <p class="text-[15px] leading-[1.75] text-foreground/85">{step.instruction}</p>
                {step.duration && (
                  <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground/45 mt-2.5 px-2.5 py-1 rounded-full bg-secondary/50 border border-border/15">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
                    </svg>
                    ~{step.duration} {t("recipe.minutes")}
                  </span>
                )}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    {/* ===== Notes + Chat ===== */}
    {(recipe.notes || currentUser) && (
      <div class:list={["mt-16 gap-6", recipe.notes && currentUser ? "grid grid-cols-1 md:grid-cols-2" : ""]}>
        {recipe.notes && (
          <div class="rounded-2xl bg-card/60 border border-border/25 p-6 backdrop-blur-sm">
            <h2 class="font-serif text-xl tracking-tight mb-3 flex items-center gap-2">
              <svg class="w-4 h-4 text-primary/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="16" x2="8" y1="13" y2="13" />
                <line x1="16" x2="8" y1="17" y2="17" />
              </svg>
              {t("recipe.notes")}
            </h2>
            <p class="text-sm text-foreground/65 whitespace-pre-wrap leading-relaxed">{recipe.notes}</p>
          </div>
        )}
        {currentUser && (
          <div class="no-print rounded-2xl bg-card/60 border border-border/25 p-6 backdrop-blur-sm">
            <RecipeChat recipeId={recipe.id} title={t("chat.title")} placeholder={t("chat.placeholder")} client:visible />
          </div>
        )}
      </div>
    )}

    {/* ===== YouTube Video ===== */}
    {youtubeId && (
      <div class="no-print mt-16">
        <h2 class="font-serif text-xl tracking-tight mb-5">{t("recipe.video")}</h2>
        <div class="aspect-video rounded-2xl overflow-hidden border border-border/25 shadow-lg shadow-black/[0.04]">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
            title={`${recipe.title} video`}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="w-full h-full"
            loading="lazy"
          />
        </div>
      </div>
    )}

    {/* ===== Instagram Embed ===== */}
    {instagramEmbedPath && !youtubeId && (
      <div class="no-print mt-16">
        <h2 class="font-serif text-xl tracking-tight mb-5">{t("recipe.video")}</h2>
        <div class="flex justify-center">
          <iframe
            src={`https://www.instagram.com/${instagramEmbedPath}/embed/`}
            title={`${recipe.title} video`}
            class="rounded-2xl border border-border/25 shadow-lg shadow-black/[0.04]"
            width="400"
            height="500"
            frameborder="0"
            scrolling="no"
            allowtransparency="true"
            loading="lazy"
          />
        </div>
      </div>
    )}

    {/* Source */}
    {recipe.sourceUrl && (
      <div class="mt-12 flex items-center gap-2 text-sm text-muted-foreground/40">
        <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
          <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
        </svg>
        {t("recipe.source")} <a href={recipe.sourceUrl} target="_blank" rel="noopener noreferrer" class="text-primary/60 hover:text-primary hover:underline transition-colors truncate">{recipe.sourceUrl}</a>
      </div>
    )}

    {/* ===== Add Cook Log ===== */}
    {currentUser && (
      <div class="no-print mt-20">
        <div class="separator-warm mb-12" />
        <div class="rounded-2xl bg-card/60 border border-border/25 p-6 md:p-8 backdrop-blur-sm">
          <h2 class="font-serif text-2xl tracking-tight mb-6 flex items-center gap-3">
            {t("cookLog.addEntry")}
            <span class="flex-1 h-px bg-gradient-to-r from-border/40 to-transparent" />
          </h2>
          <CookLogForm
            recipeId={recipe.id}
            redirectTo={`/users/${userId}/recipes/${recipe.slug}`}
            client:visible
          />
        </div>
      </div>
    )}

    {/* ===== Cook Logs ===== */}
    {logs.length > 0 && (
      <div class="no-print mt-16">
        <h2 class="font-serif text-2xl tracking-tight mb-6 flex items-center gap-3">
          {t("cookLog.title")}
          <span class="flex-1 h-px bg-gradient-to-r from-border/40 to-transparent" />
        </h2>
        <div class="space-y-4">
          {logs.map((log) => (
            <div class="rounded-2xl bg-card/50 border border-border/20 p-5 transition-all duration-300 hover:bg-card/70 hover:border-border/35">
              <div class="flex items-center gap-4 mb-3">
                {log.authorName && (
                  <span class="inline-flex items-center gap-1.5">
                    <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 text-[10px] font-semibold text-primary">
                      {log.authorName.charAt(0).toUpperCase()}
                    </span>
                    <span class="text-sm font-medium text-foreground/75">{log.authorName}</span>
                  </span>
                )}
                <time class="text-xs text-muted-foreground/40 tabular-nums">
                  {formatDate(log.cookedAt)}
                </time>
                {log.rating && (
                  <div class="flex items-center gap-1 ml-auto">
                    {Array.from({ length: 5 }).map((_, si) => (
                      <span class:list={[
                        "inline-block w-2 h-2 rounded-full transition-colors",
                        si < log.rating! ? "bg-primary" : "bg-border/40"
                      ]} />
                    ))}
                  </div>
                )}
              </div>
              {log.photoUrl && (
                <img
                  src={log.photoUrl.startsWith("/") ? `/api/uploads${log.photoUrl}` : log.photoUrl}
                  alt={t("cookLog.photoAlt")}
                  class="rounded-xl max-w-sm mb-3 border border-border/15"
                  loading="lazy"
                />
              )}
              {log.notes && <p class="text-sm text-foreground/65 leading-relaxed">{log.notes}</p>}
            </div>
          ))}
        </div>
      </div>
    )}
  </article>

  <script is:inline>
    document.getElementById('share-recipe')?.addEventListener('click', async () => {
      const url = window.location.href;
      const title = document.title;
      try {
        if (navigator.share) {
          await navigator.share({ title, url });
        } else {
          await navigator.clipboard.writeText(url);
          const btn = document.getElementById('share-recipe');
          if (btn) {
            btn.classList.add('text-primary', 'border-primary/50');
            setTimeout(() => btn.classList.remove('text-primary', 'border-primary/50'), 1500);
          }
        }
      } catch {}
    });
  </script>
</Layout>
