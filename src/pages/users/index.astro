---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db";
import { users, recipes } from "../../lib/schema";
import { eq, count } from "drizzle-orm";
import { t } from "../../lib/i18n";

const allUsers = db
  .select({
    id: users.id,
    name: users.name,
    image: users.image,
  })
  .from(users)
  .all();

// Get recipe counts per user
const recipeCounts = db
  .select({
    createdBy: recipes.createdBy,
    count: count(),
  })
  .from(recipes)
  .where(eq(recipes.isPublished, true))
  .groupBy(recipes.createdBy)
  .all();

const countsMap = new Map(recipeCounts.map((r) => [r.createdBy, r.count]));
---

<Layout title={t("nav.community")}>
  <div class="max-w-6xl mx-auto">
    <div class="mb-12">
      <h1 class="font-serif text-4xl md:text-5xl tracking-tight animate-fade-up">{t("nav.community")}</h1>
      <p class="text-muted-foreground/50 mt-2 text-sm animate-fade-up" style="animation-delay: 60ms;">
        {allUsers.length} {allUsers.length === 1 ? "member" : "members"}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {allUsers.map((u, i) => {
        const recipeCount = countsMap.get(u.id) || 0;
        const initials = u.name
          .split(" ")
          .map((n) => n[0])
          .join("")
          .toUpperCase()
          .slice(0, 2);
        return (
          <a
            href={`/users/${u.id}`}
            class="group block animate-fade-up"
            style={`animation-delay: ${i * 50}ms;`}
          >
            <div class="relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/[0.06] hover:-translate-y-1.5 p-6 text-center">
              {/* Avatar */}
              {u.image ? (
                <img
                  src={u.image}
                  alt={u.name}
                  class="w-20 h-20 rounded-full mx-auto mb-4 object-cover border-2 border-border/30"
                />
              ) : (
                <div class="w-20 h-20 rounded-full mx-auto mb-4 bg-primary/10 border-2 border-primary/20 flex items-center justify-center">
                  <span class="text-2xl font-serif text-primary">{initials}</span>
                </div>
              )}
              <h3 class="font-serif text-lg group-hover:text-primary transition-colors duration-300">
                {u.name}
              </h3>
              <p class="text-xs text-muted-foreground/50 mt-2 tabular-nums">
                {recipeCount} {t("collection.recipes")}
              </p>
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-primary/10" />
            </div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
