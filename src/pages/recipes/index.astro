---
import Layout from "../../layouts/Layout.astro";
import RecipeSearch from "../../islands/RecipeSearch";
import { db } from "../../lib/db";
import { recipes } from "../../lib/schema";
import { desc, eq, and } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/recipes");
}

const allRecipes = db
  .select()
  .from(recipes)
  .where(and(eq(recipes.isPublished, true), eq(recipes.createdBy, Astro.locals.user.id)))
  .orderBy(desc(recipes.createdAt))
  .all();
---

<Layout title={t("nav.recipes")}>
  <div class="max-w-6xl mx-auto">
    {/* Page header — editorial style */}
    <div class="flex items-end justify-between mb-12">
      <div>
        <h1 class="font-serif text-4xl md:text-5xl tracking-tight animate-fade-up">{t("nav.recipes")}</h1>
        <p class="text-muted-foreground/50 mt-2 text-sm animate-fade-up" style="animation-delay: 60ms;">
          {allRecipes.length} {allRecipes.length === 1 ? "recipe" : "recipes"}
        </p>
      </div>
      <a
        href="/recipes/new"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 transition-all duration-300 active:scale-[0.97] animate-fade-up"
        style="animation-delay: 100ms;"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M12 5v14M5 12h14" />
        </svg>
        {t("nav.newRecipe")}
      </a>
    </div>

    <RecipeSearch
      recipes={allRecipes}
      searchPlaceholder={t("recipe.search")}
      noResultsText={t("recipe.noRecipes")}
      minutesLabel={t("recipe.minutes")}
      client:visible
    />
  </div>
</Layout>
