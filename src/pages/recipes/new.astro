---
import Layout from "../../layouts/Layout.astro";
import NewRecipePage from "../../islands/NewRecipePage";
import { db } from "../../lib/db";
import { tags, collections } from "../../lib/schema";
import { eq } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect(`/login?redirect=/recipes/new`);
}

const allTags = db.select({ id: tags.id, name: tags.name }).from(tags).all();
const allCollections = db
  .select({ id: collections.id, name: collections.name })
  .from(collections)
  .where(eq(collections.createdBy, Astro.locals.user.id))
  .all();
---

<Layout title={t("nav.newRecipe")}>
  <div class="max-w-3xl mx-auto">
    <div class="mb-10 animate-fade-up">
      <h1 class="font-serif text-4xl md:text-5xl tracking-tight">{t("nav.newRecipe")}</h1>
      <p class="text-muted-foreground/50 mt-2 text-sm">Add a recipe to your collection</p>
    </div>
    <div class="animate-fade-up" style="animation-delay: 100ms;">
      <NewRecipePage tags={allTags} collections={allCollections} client:load />
    </div>
  </div>
</Layout>
