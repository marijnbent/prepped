---
import Layout from "../layouts/Layout.astro";
import ShoppingListPage from "../islands/ShoppingListPage";
import { db } from "../lib/db";
import { recipes, favorites, users } from "../lib/schema";
import { applyDirkSecretIngredients } from "../lib/recipe-secrets";
import { eq, and } from "drizzle-orm";
import { t } from "../lib/i18n";
import { getShoppingListStateForUser } from "../lib/shopping-list-db";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/shopping-list");
}

const userId = Astro.locals.user.id;
const viewerPreferences = db
  .select({ dirkSecretModeEnabled: users.dirkSecretModeEnabled })
  .from(users)
  .where(eq(users.id, userId))
  .get();
const dirkSecretModeEnabled = viewerPreferences?.dirkSecretModeEnabled ?? false;
const initialState = getShoppingListStateForUser(userId);

// Get user's own recipes
const ownRecipes = db
  .select({
    id: recipes.id,
    title: recipes.title,
    slug: recipes.slug,
    servings: recipes.servings,
    ingredients: recipes.ingredients,
    imageUrl: recipes.imageUrl,
  })
  .from(recipes)
  .where(eq(recipes.createdBy, userId))
  .all();

// Get favorited recipes from other users
const favRecipes = db
  .select({
    id: recipes.id,
    title: recipes.title,
    slug: recipes.slug,
    servings: recipes.servings,
    ingredients: recipes.ingredients,
    imageUrl: recipes.imageUrl,
  })
  .from(favorites)
  .innerJoin(recipes, eq(favorites.recipeId, recipes.id))
  .where(and(eq(favorites.userId, userId)))
  .all();

// Deduplicate (own recipes take precedence)
const seenIds = new Set(ownRecipes.map((r) => r.id));
const allRecipes = [...ownRecipes];
for (const r of favRecipes) {
  if (!seenIds.has(r.id)) {
    allRecipes.push(r);
    seenIds.add(r.id);
  }
}

const recipesData = allRecipes.map((r) => ({
  ...r,
  ingredients: applyDirkSecretIngredients(
    r.ingredients as { amount: string; unit: string; name: string; group?: string }[],
    dirkSecretModeEnabled
  ),
  imageUrl: r.imageUrl || null,
}));
---

<Layout title={t("shopping.title")}>
  <ShoppingListPage recipes={recipesData} initialState={initialState} client:load />
</Layout>
