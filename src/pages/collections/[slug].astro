---
import Layout from "../../layouts/Layout.astro";
import RecipeGrid from "../../components/RecipeGrid.astro";
import { db } from "../../lib/db";
import { collections, recipeCollections, recipes } from "../../lib/schema";
import { eq, and } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/collections");
}

const { slug } = Astro.params;
const collection = db
  .select()
  .from(collections)
  .where(and(eq(collections.slug, slug!), eq(collections.createdBy, Astro.locals.user.id)))
  .get();
if (!collection) {
  return Astro.redirect("/collections");
}

const collectionRecipesRaw = db
  .select({
    id: recipes.id,
    title: recipes.title,
    slug: recipes.slug,
    description: recipes.description,
    imageUrl: recipes.imageUrl,
    prepTime: recipes.prepTime,
    cookTime: recipes.cookTime,
    difficulty: recipes.difficulty,
    createdBy: recipes.createdBy,
  })
  .from(recipeCollections)
  .innerJoin(recipes, eq(recipeCollections.recipeId, recipes.id))
  .where(eq(recipeCollections.collectionId, collection.id))
  .all();

const collectionRecipes = collectionRecipesRaw.map((r) => ({
  ...r,
  href: r.createdBy === Astro.locals.user!.id
    ? `/recipes/${r.slug}`
    : `/users/${r.createdBy}/recipes/${r.slug}`,
}));
---

<Layout title={collection.name}>
  <div class="max-w-6xl mx-auto">
    <div class="flex items-start justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold">{collection.name}</h1>
        {collection.description && (
          <p class="text-muted-foreground mt-2">{collection.description}</p>
        )}
      </div>
      <div class="flex gap-2 shrink-0">
        <a
          href={`/collections/${collection.slug}/edit`}
          class="inline-flex items-center justify-center rounded-md border border-border px-4 py-2 text-sm font-medium hover:bg-accent transition-colors"
        >
          {t("common.edit")}
        </a>
        <button
          id="delete-collection"
          data-id={collection.id}
          data-confirm={t("collection.deleteConfirm")}
          class="inline-flex items-center justify-center rounded-md border border-destructive text-destructive px-4 py-2 text-sm font-medium hover:bg-destructive hover:text-destructive-foreground transition-colors"
        >
          {t("common.delete")}
        </button>
      </div>
    </div>
    <RecipeGrid recipes={collectionRecipes} />
  </div>

  <script is:inline>
    document.addEventListener("click", async (e) => {
      const btn = e.target.closest("#delete-collection");
      if (!btn) return;
      if (!confirm(btn.getAttribute("data-confirm"))) return;
      const id = btn.getAttribute("data-id");
      try {
        const res = await fetch("/api/collections/" + id, { method: "POST" });
        if (res.ok) {
          window.location.href = "/collections";
        } else {
          const text = await res.text();
          alert("Delete failed: " + (text || res.status));
        }
      } catch (err) {
        alert("Delete failed: " + err.message);
      }
    });
  </script>
</Layout>
