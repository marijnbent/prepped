---
import Layout from "../../layouts/Layout.astro";
import RecipeGrid from "../../components/RecipeGrid.astro";
import { db } from "../../lib/db";
import { collections, recipeCollections, recipes } from "../../lib/schema";
import { eq, and } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/collections");
}

const { slug } = Astro.params;
const collection = db
  .select()
  .from(collections)
  .where(and(eq(collections.slug, slug!), eq(collections.createdBy, Astro.locals.user.id)))
  .get();
if (!collection) {
  return Astro.redirect("/collections");
}

const collectionRecipesRaw = db
  .select({
    id: recipes.id,
    title: recipes.title,
    slug: recipes.slug,
    description: recipes.description,
    imageUrl: recipes.imageUrl,
    prepTime: recipes.prepTime,
    cookTime: recipes.cookTime,
    difficulty: recipes.difficulty,
    createdBy: recipes.createdBy,
  })
  .from(recipeCollections)
  .innerJoin(recipes, eq(recipeCollections.recipeId, recipes.id))
  .where(eq(recipeCollections.collectionId, collection.id))
  .all();

const collectionRecipes = collectionRecipesRaw.map((r) => ({
  ...r,
  href: r.createdBy === Astro.locals.user!.id
    ? `/recipes/${r.slug}`
    : `/users/${r.createdBy}/recipes/${r.slug}`,
}));
---

<Layout title={collection.name}>
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between mb-8 animate-fade-up">
      <div>
        <a href="/collections" class="inline-flex items-center gap-1.5 text-xs text-muted-foreground/40 hover:text-primary transition-colors mb-3 group/back">
          <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover/back:-translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m15 18-6-6 6-6" />
          </svg>
          {t("nav.collections")}
        </a>
        <h1 class="font-serif text-4xl md:text-5xl tracking-tight text-foreground leading-[1.1]">{collection.name}</h1>
        {collection.description && (
          <p class="text-lg text-muted-foreground/60 mt-3 max-w-2xl leading-relaxed">{collection.description}</p>
        )}
        <p class="text-xs text-muted-foreground/35 mt-3 tabular-nums">
          {collectionRecipes.length} {t("collection.recipes")}
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <a
          href={`/collections/${collection.slug}/edit`}
          class="inline-flex items-center justify-center gap-1.5 h-7 rounded-full border border-border/40 bg-secondary/40 px-3 text-xs font-medium hover:bg-secondary/70 hover:border-border/60 transition-all duration-200"
        >
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
          </svg>
          {t("common.edit")}
        </a>
        <button
          id="delete-collection"
          data-id={collection.id}
          data-confirm={t("collection.deleteConfirm")}
          class="inline-flex items-center justify-center h-7 w-7 rounded-full border border-destructive/25 text-destructive hover:bg-destructive hover:text-destructive-foreground hover:border-destructive transition-all duration-200"
        >
          <svg class="w-3 h-3 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 6h18" /><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6" /><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2" />
          </svg>
          <span class="sr-only">{t("common.delete")}</span>
        </button>
      </div>
    </div>
    <div class="separator-warm mb-10 animate-fade-up" style="animation-delay: 60ms;" />
    <RecipeGrid recipes={collectionRecipes} />
  </div>

  <script is:inline>
    document.addEventListener("click", async (e) => {
      const btn = e.target.closest("#delete-collection");
      if (!btn) return;
      if (!confirm(btn.getAttribute("data-confirm"))) return;
      const id = btn.getAttribute("data-id");
      try {
        const res = await fetch("/api/collections/" + id, { method: "POST" });
        if (res.ok) {
          window.location.href = "/collections";
        } else {
          const text = await res.text();
          alert("Delete failed: " + (text || res.status));
        }
      } catch (err) {
        alert("Delete failed: " + err.message);
      }
    });
  </script>
</Layout>
