---
import Layout from "../../layouts/Layout.astro";
import CollectionForm from "../../islands/CollectionForm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/collections/new");
}
---

<Layout title={t("collection.new")}>
  <div class="max-w-lg mx-auto animate-fade-up">
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight text-foreground leading-[1.1] mb-8">{t("collection.new")}</h1>
    <CollectionForm client:load />
  </div>
</Layout>
