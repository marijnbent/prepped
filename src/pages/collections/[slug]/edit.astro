---
import Layout from "../../../layouts/Layout.astro";
import CollectionForm from "../../../islands/CollectionForm";
import { db } from "../../../lib/db";
import { collections } from "../../../lib/schema";
import { eq, and } from "drizzle-orm";
import { t } from "../../../lib/i18n";

const { slug } = Astro.params;

if (!Astro.locals.user) {
  return Astro.redirect(`/login?redirect=/collections/${slug}/edit`);
}

const collection = db
  .select()
  .from(collections)
  .where(and(eq(collections.slug, slug!), eq(collections.createdBy, Astro.locals.user.id)))
  .get();
if (!collection) {
  return Astro.redirect("/collections");
}
---

<Layout title={`${t("collection.editPrefix")} - ${collection.name}`}>
  <div class="max-w-lg mx-auto animate-fade-up">
    <p class="text-[11px] uppercase tracking-[0.12em] text-primary font-medium mb-2">{t("collection.editPrefix")}</p>
    <h1 class="font-serif text-4xl md:text-5xl tracking-tight text-foreground leading-[1.1] mb-8">{collection.name}</h1>
    <CollectionForm
      initial={{
        id: collection.id,
        name: collection.name,
        description: collection.description || "",
        imageUrl: collection.imageUrl || "",
        sortOrder: collection.sortOrder,
      }}
      client:load
    />
  </div>
</Layout>
