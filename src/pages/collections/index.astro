---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db";
import { collections, recipeCollections, recipes } from "../../lib/schema";
import { eq, count, desc, and, inArray, isNotNull } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/collections");
}

const allCollections = db
  .select()
  .from(collections)
  .where(eq(collections.createdBy, Astro.locals.user.id))
  .orderBy(collections.sortOrder)
  .all();
const collectionIds = allCollections.map((col) => col.id);

// Get recipe counts
const counts = collectionIds.length === 0
  ? []
  : db
      .select({
        collectionId: recipeCollections.collectionId,
        count: count(),
      })
      .from(recipeCollections)
      .where(inArray(recipeCollections.collectionId, collectionIds))
      .groupBy(recipeCollections.collectionId)
      .all();

const countsMap = new Map(counts.map((c) => [c.collectionId, c.count]));

// Sort collections by recipe count (descending)
allCollections.sort((a, b) => (countsMap.get(b.id) || 0) - (countsMap.get(a.id) || 0));

// Get up to 4 recent recipe images per collection for the thumbnail grid
const thumbsMap = new Map<number, string[]>();
const collectionsNeedingThumbs = allCollections.filter((col) => !col.imageUrl).map((col) => col.id);
if (collectionsNeedingThumbs.length > 0) {
  const thumbRows = db
    .select({
      collectionId: recipeCollections.collectionId,
      imageUrl: recipes.imageUrl,
    })
    .from(recipeCollections)
    .innerJoin(recipes, eq(recipeCollections.recipeId, recipes.id))
    .where(and(inArray(recipeCollections.collectionId, collectionsNeedingThumbs), isNotNull(recipes.imageUrl)))
    .orderBy(recipeCollections.collectionId, desc(recipes.createdAt))
    .all();

  for (const row of thumbRows) {
    if (!row.imageUrl) continue;
    const existing = thumbsMap.get(row.collectionId) || [];
    if (existing.length >= 4) continue;
    existing.push(row.imageUrl);
    thumbsMap.set(row.collectionId, existing);
  }
}
---

<Layout title={t("nav.collections")}>
  <div class="max-w-6xl mx-auto">
    {/* Page header */}
    <div class="flex items-end justify-between mb-10">
      <div>
        <h1 class="font-serif text-4xl md:text-5xl tracking-tight animate-fade-up">{t("nav.collections")}</h1>
        <p class="text-muted-foreground/40 mt-2 text-sm animate-fade-up" style="animation-delay: 60ms;">
          {allCollections.length} {allCollections.length === 1 ? t("count.collection") : t("count.collections")}
        </p>
      </div>
      <a
        href="/collections/new"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/25 hover:brightness-110 transition-all duration-300 active:scale-[0.97] animate-fade-up"
        style="animation-delay: 100ms;"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M12 5v14M5 12h14" />
        </svg>
        {t("collection.new")}
      </a>
    </div>

    <div class="separator-warm mb-10 animate-fade-up" style="animation-delay: 80ms;" />

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
      {/* Favorites card */}
      <a
        href="/favorites"
        class="group block animate-fade-up"
      >
        <div class="card-shine relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 ease-out hover:border-rose-400/25 hover:shadow-[0_8px_30px_-6px] hover:shadow-rose-400/[0.08] hover:-translate-y-1">
          <div class="aspect-[16/9] bg-gradient-to-br from-rose-500/[0.08] via-pink-500/[0.04] to-amber-500/[0.08] flex items-center justify-center relative overflow-hidden">
            <div class="absolute top-4 right-4 w-20 h-20 rounded-full border border-rose-400/15 animate-float" />
            <div class="absolute bottom-6 left-6 w-12 h-12 rounded-full bg-rose-400/[0.06]" />
            <svg class="w-10 h-10 text-rose-400/30 transition-all duration-500 group-hover:text-rose-400/50 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" stroke="none">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
            </svg>
          </div>
          <div class="p-4 pb-5">
            <h3 class="font-serif text-lg leading-snug group-hover:text-rose-500 transition-colors duration-300">
              {t("collection.favorites")}
            </h3>
            <p class="text-[13px] text-muted-foreground/50 mt-1.5 leading-relaxed">{t("collection.favoritesDesc")}</p>
          </div>
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-rose-400/[0.08]" />
        </div>
      </a>

      {allCollections.map((col, i) => {
        const recipeCount = countsMap.get(col.id) || 0;
        return (
          <a
            href={`/collections/${col.slug}`}
            class="group block animate-fade-up"
            style={`animation-delay: ${(i + 1) * 50}ms;`}
          >
            <div class="card-shine relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 ease-out hover:border-primary/25 hover:shadow-[0_8px_30px_-6px] hover:shadow-primary/[0.08] hover:-translate-y-1">
              {/* Image area */}
              {col.imageUrl ? (
                <div class="aspect-[16/9] overflow-hidden relative">
                  <img
                    src={col.imageUrl.startsWith("/") ? `/api/uploads${col.imageUrl}` : col.imageUrl}
                    alt={col.name}
                    class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-[1.06]"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-card via-card/30 to-transparent opacity-60 pointer-events-none" />
                </div>
              ) : thumbsMap.has(col.id) ? (
                <div class="aspect-[16/9] grid grid-cols-2 grid-rows-2 overflow-hidden">
                  {thumbsMap.get(col.id)!.map((img) => (
                    <div class="overflow-hidden relative">
                      <img
                        src={img.startsWith("/") ? `/api/uploads${img}` : img}
                        alt=""
                        class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-[1.06]"
                        loading="lazy"
                      />
                    </div>
                  ))}
                  {Array.from({ length: 4 - thumbsMap.get(col.id)!.length }).map(() => (
                    <div class="bg-gradient-to-br from-secondary to-accent/20" />
                  ))}
                </div>
              ) : (
                <div class="aspect-[16/9] bg-gradient-to-br from-secondary via-muted/80 to-primary/[0.06] flex items-center justify-center relative overflow-hidden">
                  <div class="absolute top-4 right-4 w-20 h-20 rounded-full border border-primary/[0.08] animate-float" />
                  <div class="absolute bottom-6 left-6 w-12 h-12 rounded-full bg-primary/[0.04]" />
                  <svg class="w-10 h-10 text-muted-foreground/15 transition-all duration-500 group-hover:text-primary/20 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
                  </svg>
                </div>
              )}

              {/* Content */}
              <div class="p-4 pb-5">
                <h3 class="font-serif text-lg leading-snug group-hover:text-primary transition-colors duration-300">
                  {col.name}
                </h3>
                {col.description && (
                  <p class="text-[13px] text-muted-foreground/50 mt-1.5 line-clamp-2 leading-relaxed">{col.description}</p>
                )}
                <div class="flex items-center gap-2 mt-3 pt-3 border-t border-border/20">
                  <span class="text-xs text-muted-foreground/40 tabular-nums">
                    {recipeCount} {t("collection.recipes")}
                  </span>
                </div>
              </div>

              {/* Hover glow */}
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-primary/[0.08]" />
            </div>
          </a>
        );
      })}
    </div>

    {allCollections.length === 0 && (
      <div class="text-center py-20">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-secondary/60 mb-5 border border-border/20">
          <svg class="w-7 h-7 text-muted-foreground/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
          </svg>
        </div>
        <p class="text-muted-foreground/60 text-base font-serif">{t("collection.noCustom")}</p>
        <p class="text-muted-foreground/30 text-sm mt-1.5 max-w-xs mx-auto leading-relaxed">{t("collection.noCustom")}</p>
      </div>
    )}
  </div>
</Layout>
