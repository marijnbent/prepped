---
import Layout from "../../layouts/Layout.astro";
import { db } from "../../lib/db";
import { collections, recipeCollections, recipes } from "../../lib/schema";
import { eq, count, desc } from "drizzle-orm";
import { t } from "../../lib/i18n";

const allCollections = db
  .select()
  .from(collections)
  .orderBy(collections.sortOrder)
  .all();

// Get recipe counts
const counts = db
  .select({
    collectionId: recipeCollections.collectionId,
    count: count(),
  })
  .from(recipeCollections)
  .groupBy(recipeCollections.collectionId)
  .all();

const countsMap = new Map(counts.map((c) => [c.collectionId, c.count]));

// Get up to 4 recent recipe images per collection for the thumbnail grid
const thumbsMap = new Map<number, string[]>();
for (const col of allCollections) {
  if (col.imageUrl) continue;
  const imgs = db
    .select({ imageUrl: recipes.imageUrl })
    .from(recipeCollections)
    .innerJoin(recipes, eq(recipeCollections.recipeId, recipes.id))
    .where(eq(recipeCollections.collectionId, col.id))
    .orderBy(desc(recipes.createdAt))
    .limit(4)
    .all()
    .filter((r) => r.imageUrl)
    .map((r) => r.imageUrl!);
  if (imgs.length > 0) thumbsMap.set(col.id, imgs);
}
---

<Layout title={t("nav.collections")}>
  <div class="max-w-6xl mx-auto">
    {/* Page header */}
    <div class="flex items-end justify-between mb-12">
      <div>
        <h1 class="font-serif text-4xl md:text-5xl tracking-tight animate-fade-up">{t("nav.collections")}</h1>
        <p class="text-muted-foreground/50 mt-2 text-sm animate-fade-up" style="animation-delay: 60ms;">
          {allCollections.length} {allCollections.length === 1 ? "collection" : "collections"}
        </p>
      </div>
      {Astro.locals.user && (
        <a
          href="/collections/new"
          class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 transition-all duration-300 active:scale-[0.97] animate-fade-up"
          style="animation-delay: 100ms;"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M12 5v14M5 12h14" />
          </svg>
          New Collection
        </a>
      )}
    </div>

    {allCollections.length === 0 ? (
      <div class="text-center py-28">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-secondary/80 border border-border/30 mb-6">
          <svg class="w-9 h-9 text-muted-foreground/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
          </svg>
        </div>
        <p class="text-muted-foreground text-lg font-serif">{t("collection.noCollections")}</p>
        <p class="text-muted-foreground/40 text-sm mt-2">Create a collection to organize your recipes</p>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
        {allCollections.map((col, i) => {
          const recipeCount = countsMap.get(col.id) || 0;
          return (
            <a
              href={`/collections/${col.slug}`}
              class="group block animate-fade-up"
              style={`animation-delay: ${i * 50}ms;`}
            >
              <div class="relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/[0.06] hover:-translate-y-1.5">
                {/* Image area */}
                {col.imageUrl ? (
                  <div class="aspect-[16/9] overflow-hidden relative">
                    <img
                      src={col.imageUrl.startsWith("/") ? `/api/uploads${col.imageUrl}` : col.imageUrl}
                      alt={col.name}
                      class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110 group-hover:brightness-110"
                      loading="lazy"
                    />
                    <div class="absolute inset-0 bg-gradient-to-t from-card via-card/30 to-transparent opacity-60 pointer-events-none" />
                  </div>
                ) : thumbsMap.has(col.id) ? (
                  <div class="aspect-[16/9] grid grid-cols-2 grid-rows-2 overflow-hidden">
                    {thumbsMap.get(col.id)!.map((img) => (
                      <div class="overflow-hidden relative">
                        <img
                          src={img.startsWith("/") ? `/api/uploads${img}` : img}
                          alt=""
                          class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110"
                          loading="lazy"
                        />
                      </div>
                    ))}
                    {Array.from({ length: 4 - thumbsMap.get(col.id)!.length }).map(() => (
                      <div class="bg-gradient-to-br from-secondary to-accent/20" />
                    ))}
                  </div>
                ) : (
                  <div class="aspect-[16/9] bg-gradient-to-br from-secondary via-muted to-accent/20 flex items-center justify-center relative overflow-hidden">
                    <div class="absolute top-4 right-4 w-20 h-20 rounded-full border border-primary/10 animate-float" />
                    <div class="absolute bottom-6 left-6 w-12 h-12 rounded-full bg-primary/5" />
                    <svg class="w-10 h-10 text-muted-foreground/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z" />
                    </svg>
                  </div>
                )}

                {/* Content */}
                <div class="p-4 pb-5">
                  <h3 class="font-serif text-lg leading-snug group-hover:text-primary transition-colors duration-300">
                    {col.name}
                  </h3>
                  {col.description && (
                    <p class="text-sm text-muted-foreground/70 mt-1.5 line-clamp-2 leading-relaxed">{col.description}</p>
                  )}
                  <div class="flex items-center gap-2 mt-3 pt-3 border-t border-border/30">
                    <span class="text-xs text-muted-foreground/50 tabular-nums">
                      {recipeCount} {t("collection.recipes")}
                    </span>
                  </div>
                </div>

                {/* Hover glow */}
                <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-primary/10" />
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>
