---
import Layout from "../layouts/Layout.astro";
import LoginForm from "../islands/LoginForm";
import { t } from "../lib/i18n";

const redirect = Astro.url.searchParams.get("redirect") || "/";
const inviteRequired = !!import.meta.env.INVITE_CODE;
const authMode = import.meta.env.AUTH_MODE || "password";
const isSimple = authMode === "simple";

if (Astro.locals.user) {
  return Astro.redirect(redirect);
}
---

<Layout title={t("auth.pageTitle")}>
  <div class="flex items-center justify-center min-h-[70vh] py-12 relative overflow-hidden">
    {/* Atmospheric background */}
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/3 w-[400px] h-[300px] rounded-full bg-primary/[0.06] blur-[120px] animate-glow-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-[300px] h-[200px] rounded-full bg-accent/[0.04] blur-[80px]" style="animation-delay: 1.5s;" />
    </div>

    <div class="relative w-full max-w-sm mx-auto animate-fade-up">
      <div class="rounded-2xl bg-card/60 backdrop-blur-sm border border-border/30 p-8">
        {/* Branding */}
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-primary/10 text-primary mb-4 border border-primary/20">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
            </svg>
          </div>
          <h1 class="font-serif text-2xl tracking-tight text-foreground">{isSimple ? t("auth.whosCooking") : t("auth.welcomeBack")}</h1>
          <p class="text-sm text-muted-foreground/60 mt-1">{isSimple ? t("auth.enterName") : t("auth.signInDesc")}</p>
        </div>

        {/* Login form */}
        <LoginForm redirect={redirect} inviteRequired={inviteRequired} authMode={authMode} client:load />
      </div>
    </div>
  </div>
</Layout>
