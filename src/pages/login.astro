---
import Layout from "../layouts/Layout.astro";
import LoginForm from "../islands/LoginForm";

const redirect = Astro.url.searchParams.get("redirect") || "/";
const inviteRequired = !!import.meta.env.INVITE_CODE;

if (Astro.locals.user) {
  return Astro.redirect(redirect);
}
---

<Layout title="Login">
  <div class="flex items-center justify-center min-h-[70vh] py-12 relative overflow-hidden">
    {/* Atmospheric background */}
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/3 left-1/3 w-[400px] h-[300px] rounded-full bg-primary/[0.06] blur-[120px] animate-glow-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-[300px] h-[200px] rounded-full bg-accent/[0.04] blur-[80px]" style="animation-delay: 1.5s;" />
    </div>

    <div class="relative w-full max-w-sm mx-auto animate-fade-up">
      {/* Branding */}
      <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-primary/10 text-primary mb-5 border border-primary/20">
          <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
          </svg>
        </div>
        <h1 class="font-serif text-3xl tracking-tight text-foreground">Welcome back</h1>
        <p class="text-sm text-muted-foreground/60 mt-2">Sign in to your family recipes</p>
      </div>

      {/* Login form */}
      <div class="rounded-2xl bg-card/60 backdrop-blur-sm border border-border/30 p-6">
        <LoginForm redirect={redirect} inviteRequired={inviteRequired} client:load />
      </div>
    </div>
  </div>
</Layout>
