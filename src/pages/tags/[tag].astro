---
import Layout from "../../layouts/Layout.astro";
import RecipeGrid from "../../components/RecipeGrid.astro";
import { db } from "../../lib/db";
import { tags, recipeTags, recipes } from "../../lib/schema";
import { eq, and } from "drizzle-orm";
import { t } from "../../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const { tag: tagSlug } = Astro.params;
const tag = db.select().from(tags).where(eq(tags.slug, tagSlug!)).get();
if (!tag) {
  return Astro.redirect("/recipes");
}

const tagRecipes = db
  .select({
    id: recipes.id,
    title: recipes.title,
    slug: recipes.slug,
    description: recipes.description,
    imageUrl: recipes.imageUrl,
    prepTime: recipes.prepTime,
    cookTime: recipes.cookTime,
    difficulty: recipes.difficulty,
  })
  .from(recipeTags)
  .innerJoin(recipes, eq(recipeTags.recipeId, recipes.id))
  .where(and(eq(recipeTags.tagId, tag.id), eq(recipes.createdBy, Astro.locals.user.id)))
  .all();
---

<Layout title={tag.name}>
  <div class="max-w-6xl mx-auto">
    <h1 class="text-3xl font-bold mb-6">
      <span class="text-muted-foreground">{t("tag.prefix")}</span> {tag.name}
    </h1>
    <RecipeGrid recipes={tagRecipes} />
  </div>
</Layout>
