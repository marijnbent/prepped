---
import Layout from "../layouts/Layout.astro";
import ProfileForm from "../islands/ProfileForm.tsx";
import { db } from "../lib/db";
import { users } from "../lib/schema";
import { eq } from "drizzle-orm";
import { t } from "../lib/i18n";

if (!Astro.locals.user) {
  return Astro.redirect("/login?redirect=/profile");
}

const user = db.select({ importPrompt: users.importPrompt, chatPrompt: users.chatPrompt })
  .from(users)
  .where(eq(users.id, Astro.locals.user.id))
  .get();
---

<Layout title={t("profile.title")}>
  <div class="max-w-2xl mx-auto">
    <div class="mb-10 animate-fade-up">
      <h1 class="font-serif text-4xl md:text-5xl tracking-tight">{t("profile.title")}</h1>
      <p class="text-muted-foreground/50 mt-2 text-sm">{t("profile.customizeHint").replace("{link}", t("profile.title").toLowerCase())}</p>
    </div>

    <div class="animate-fade-up" style="animation-delay: 100ms;">
      <ProfileForm
        client:load
        importPrompt={user?.importPrompt || ""}
        chatPrompt={user?.chatPrompt || ""}
      />
    </div>
  </div>
</Layout>
