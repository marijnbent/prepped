---
import Layout from "../layouts/Layout.astro";
import RecipeCard from "../components/RecipeCard.astro";
import { db } from "../lib/db";
import { recipes, cookLogs, collections, recipeCollections, users } from "../lib/schema";
import { desc, eq, count } from "drizzle-orm";
import { t, formatDate } from "../lib/i18n";

const recentRecipes = db
  .select()
  .from(recipes)
  .where(eq(recipes.isPublished, true))
  .orderBy(desc(recipes.createdAt))
  .limit(6)
  .all();

const recentLogs = db
  .select({
    id: cookLogs.id,
    photoUrl: cookLogs.photoUrl,
    notes: cookLogs.notes,
    rating: cookLogs.rating,
    cookedAt: cookLogs.cookedAt,
    recipeTitle: recipes.title,
    recipeSlug: recipes.slug,
    recipeImageUrl: recipes.imageUrl,
    authorName: users.name,
  })
  .from(cookLogs)
  .innerJoin(recipes, eq(cookLogs.recipeId, recipes.id))
  .leftJoin(users, eq(cookLogs.createdBy, users.id))
  .orderBy(desc(cookLogs.cookedAt))
  .limit(4)
  .all();

// Stats
const totalRecipes = db.select({ count: count() }).from(recipes).where(eq(recipes.isPublished, true)).get()!.count;
const totalLogs = db.select({ count: count() }).from(cookLogs).get()!.count;
const totalCollections = db.select({ count: count() }).from(collections).get()!.count;
const totalMembers = db.select({ count: count() }).from(users).get()!.count;

const stats = [
  { label: t("nav.recipes"), value: totalRecipes, icon: "recipes" },
  { label: t("nav.collections"), value: totalCollections, icon: "collections" },
  { label: t("nav.cookLog"), value: totalLogs, icon: "logs" },
  { label: "Members", value: totalMembers, icon: "members" },
];
---

<Layout>
  <div class="max-w-6xl mx-auto">

    {/* ===== Hero — dramatic editorial entrance ===== */}
    <section class="relative pt-16 pb-24 md:pt-24 md:pb-32 text-center overflow-hidden">
      {/* Background atmospheric elements */}
      <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-primary/[0.06] blur-[100px] animate-glow-pulse" />
        <div class="absolute bottom-0 right-[10%] w-[300px] h-[200px] rounded-full bg-accent/[0.04] blur-[80px]" style="animation-delay: 1.5s;" />
      </div>

      <div class="relative">
        {/* Decorative label */}
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/20 bg-primary/5 text-primary text-[13px] font-medium tracking-wide mb-8 animate-fade-in">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
          </svg>
          {t("site.description")}
        </div>

        <h1
          class="font-serif text-5xl md:text-7xl lg:text-8xl tracking-tight text-foreground leading-[1.05] animate-fade-up"
        >
          {t("site.title")}
        </h1>
        <p
          class="text-lg md:text-xl text-muted-foreground mt-5 max-w-lg mx-auto leading-relaxed animate-fade-up"
          style="animation-delay: 100ms;"
        >
          {t("site.description")}
        </p>

        <div
          class="flex flex-wrap gap-4 justify-center mt-12 animate-fade-up"
          style="animation-delay: 200ms;"
        >
          <a
            href="/recipes"
            class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 transition-all duration-300 active:scale-[0.97]"
          >
            {t("nav.recipes")}
          </a>
          {Astro.locals.user && (
            <a
              href="/recipes/new"
              class="inline-flex items-center gap-2 rounded-xl border border-border bg-secondary/50 backdrop-blur-sm px-8 py-3 text-sm font-semibold hover:bg-secondary hover:border-border/80 transition-all duration-300 active:scale-[0.97]"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M12 5v14M5 12h14" />
              </svg>
              {t("nav.newRecipe")}
            </a>
          )}
        </div>
      </div>
    </section>

    {/* ===== Stats — minimal with editorial type ===== */}
    <section class="grid grid-cols-2 sm:grid-cols-4 gap-px mb-24 rounded-2xl overflow-hidden border border-border/30 bg-border/20">
      {stats.map((stat, i) => (
        <div
          class="bg-card/60 backdrop-blur-sm p-6 md:p-8 text-center transition-all duration-300 hover:bg-card animate-fade-up"
          style={`animation-delay: ${i * 70}ms;`}
        >
          <div class="font-serif text-4xl md:text-5xl text-foreground tracking-tight">{stat.value}</div>
          <div class="text-[11px] uppercase tracking-[0.12em] text-muted-foreground/60 mt-2 font-medium">{stat.label}</div>
        </div>
      ))}
    </section>

    {/* ===== Recent Recipes ===== */}
    {recentRecipes.length > 0 && (
      <section class="mb-24">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="font-serif text-3xl md:text-4xl tracking-tight">{t("nav.recipes")}</h2>
            <p class="text-sm text-muted-foreground/60 mt-2">
              {recentRecipes.length > 1 ? `${recentRecipes.length} latest` : "Latest recipe"}
            </p>
          </div>
          <a
            href="/recipes"
            class="group/link inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.06em] font-medium text-muted-foreground hover:text-primary transition-colors duration-300"
          >
            View all
            <svg
              class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            >
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
          {recentRecipes.map((recipe, i) => (
            <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms;`}>
              <RecipeCard recipe={recipe} />
            </div>
          ))}
        </div>
      </section>
    )}

    {/* ===== Recent Cook Logs ===== */}
    {recentLogs.length > 0 && (
      <section class="mb-24">
        <div class="flex items-end justify-between mb-10">
          <div>
            <h2 class="font-serif text-3xl md:text-4xl tracking-tight">{t("cookLog.title")}</h2>
            <p class="text-sm text-muted-foreground/60 mt-2">
              Recent cooking sessions
            </p>
          </div>
          <a
            href="/cook-log"
            class="group/link inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.06em] font-medium text-muted-foreground hover:text-primary transition-colors duration-300"
          >
            View all
            <svg
              class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1"
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            >
              <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 md:gap-6">
          {recentLogs.map((log, i) => (
            <a
              href={`/recipes/${log.recipeSlug}`}
              class="group block animate-fade-up"
              style={`animation-delay: ${i * 60}ms;`}
            >
              <div class="rounded-2xl bg-card/60 backdrop-blur-sm overflow-hidden border border-border/30 transition-all duration-500 hover:border-primary/20 hover:shadow-2xl hover:shadow-primary/[0.04] hover:-translate-y-1">
                <div class="flex">
                  {(log.photoUrl || log.recipeImageUrl) && (
                    <div class="w-32 h-32 shrink-0 overflow-hidden relative">
                      <img
                        src={(() => {
                          const url = log.photoUrl || log.recipeImageUrl!;
                          return url.startsWith("/") ? `/api/uploads${url}` : url;
                        })()}
                        alt=""
                        class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110 group-hover:brightness-110"
                        loading="lazy"
                      />
                      {/* Fade edge into card */}
                      <div class="absolute inset-y-0 right-0 w-8 bg-gradient-to-l from-card/60 to-transparent pointer-events-none" />
                    </div>
                  )}
                  <div class="flex-1 p-4 min-w-0 flex flex-col justify-center">
                    <div class="flex items-start justify-between gap-3">
                      <h3 class="font-serif text-lg group-hover:text-primary transition-colors duration-300 line-clamp-1">
                        {log.recipeTitle}
                      </h3>
                      {log.rating && (
                        <div class="shrink-0 flex items-center gap-0.5 mt-1">
                          {Array.from({ length: 5 }).map((_, si) => (
                            <span class:list={[
                              "inline-block w-1.5 h-1.5 rounded-full",
                              si < log.rating! ? "bg-primary" : "bg-border"
                            ]} />
                          ))}
                        </div>
                      )}
                    </div>
                    {log.notes && (
                      <p class="text-sm text-muted-foreground/70 line-clamp-1 mt-1.5 leading-relaxed">{log.notes}</p>
                    )}
                    <div class="flex items-center gap-2 mt-3 text-xs text-muted-foreground/50">
                      {log.authorName && <span class="font-medium text-muted-foreground/70">{log.authorName}</span>}
                      {log.authorName && <span class="text-border/50">&middot;</span>}
                      <time class="tabular-nums">{formatDate(log.cookedAt)}</time>
                    </div>
                  </div>
                </div>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>
