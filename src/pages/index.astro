---
import Layout from "../layouts/Layout.astro";
import RecipeCard from "../components/RecipeCard.astro";
import { db } from "../lib/db";
import { recipes, cookLogs, collections, recipeCollections, users } from "../lib/schema";
import { desc, eq, count, ne, and } from "drizzle-orm";
import { t, formatDate } from "../lib/i18n";

const user = Astro.locals.user;

// Stats (always shown)
const totalRecipes = db.select({ count: count() }).from(recipes).where(eq(recipes.isPublished, true)).get()!.count;
const totalLogs = db.select({ count: count() }).from(cookLogs).get()!.count;
const totalMembers = db.select({ count: count() }).from(users).get()!.count;

// Logged-in data
let myRecipes: any[] = [];
let communityRecipes: any[] = [];
let recentLogs: any[] = [];

if (user) {
  myRecipes = db
    .select()
    .from(recipes)
    .where(and(eq(recipes.isPublished, true), eq(recipes.createdBy, user.id)))
    .orderBy(desc(recipes.createdAt))
    .limit(6)
    .all();

  communityRecipes = db
    .select({
      id: recipes.id,
      title: recipes.title,
      slug: recipes.slug,
      description: recipes.description,
      imageUrl: recipes.imageUrl,
      prepTime: recipes.prepTime,
      cookTime: recipes.cookTime,
      difficulty: recipes.difficulty,
      createdBy: recipes.createdBy,
      authorName: users.name,
    })
    .from(recipes)
    .innerJoin(users, eq(recipes.createdBy, users.id))
    .where(and(eq(recipes.isPublished, true), ne(recipes.createdBy, user.id)))
    .orderBy(desc(recipes.createdAt))
    .limit(6)
    .all();

  recentLogs = db
    .select({
      id: cookLogs.id,
      photoUrl: cookLogs.photoUrl,
      notes: cookLogs.notes,
      rating: cookLogs.rating,
      cookedAt: cookLogs.cookedAt,
      recipeTitle: recipes.title,
      recipeSlug: recipes.slug,
      recipeImageUrl: recipes.imageUrl,
      authorName: users.name,
    })
    .from(cookLogs)
    .innerJoin(recipes, eq(cookLogs.recipeId, recipes.id))
    .leftJoin(users, eq(cookLogs.createdBy, users.id))
    .where(eq(cookLogs.createdBy, user.id))
    .orderBy(desc(cookLogs.cookedAt))
    .limit(4)
    .all();
} else {
  // Logged-out: show all recent for the landing
  communityRecipes = db
    .select({
      id: recipes.id,
      title: recipes.title,
      slug: recipes.slug,
      description: recipes.description,
      imageUrl: recipes.imageUrl,
      prepTime: recipes.prepTime,
      cookTime: recipes.cookTime,
      difficulty: recipes.difficulty,
      createdBy: recipes.createdBy,
      authorName: users.name,
    })
    .from(recipes)
    .innerJoin(users, eq(recipes.createdBy, users.id))
    .where(eq(recipes.isPublished, true))
    .orderBy(desc(recipes.createdAt))
    .limit(6)
    .all();
}

const firstName = user?.name?.split(" ")[0] || "";
---

<Layout>
  <div class="max-w-6xl mx-auto">

    {user ? (
      <>
        {/* ========== LOGGED-IN DASHBOARD ========== */}

        {/* Greeting + quick actions */}
        <section class="pt-6 pb-10 md:pt-10 md:pb-14 animate-fade-up">
          <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6">
            <div>
              <p class="text-[11px] uppercase tracking-[0.14em] text-primary font-semibold mb-2">
                {t("site.title")}
              </p>
              <h1 class="font-serif text-3xl md:text-4xl tracking-tight">
                {t("home.welcome")}, {firstName}
              </h1>
            </div>
            <div class="flex items-center gap-2">
              <a
                href="/recipes/new"
                class="inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 transition-all duration-300 active:scale-[0.97]"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <path d="M12 5v14M5 12h14" />
                </svg>
                {t("nav.newRecipe")}
              </a>
              <a
                href="/users"
                class="inline-flex items-center gap-2 rounded-xl border border-border/50 bg-secondary/50 px-5 py-2.5 text-sm font-medium hover:bg-secondary hover:border-border transition-all duration-200"
              >
                <svg class="w-4 h-4 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="8" r="4" /><path d="M20 21a8 8 0 0 0-16 0" />
                </svg>
                {t("nav.community")}
              </a>
            </div>
          </div>
        </section>

        {/* Your recent recipes */}
        {myRecipes.length > 0 && (
          <section class="mb-16">
            <div class="flex items-end justify-between mb-8">
              <h2 class="font-serif text-2xl md:text-3xl tracking-tight">{t("nav.recipes")}</h2>
              <a
                href="/recipes"
                class="group/link inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.06em] font-medium text-muted-foreground hover:text-primary transition-colors duration-300"
              >
                {t("home.viewAll")}
                <svg class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
              {myRecipes.map((recipe, i) => (
                <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms;`}>
                  <RecipeCard recipe={recipe} />
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Empty state for new users */}
        {myRecipes.length === 0 && (
          <section class="mb-16 rounded-2xl border border-dashed border-border/60 bg-card/30 p-10 md:p-14 text-center animate-fade-up">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary/10 mb-5">
              <svg class="w-7 h-7 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
              </svg>
            </div>
            <h3 class="font-serif text-xl mb-2">{t("home.emptyTitle")}</h3>
            <p class="text-sm text-muted-foreground/60 mb-6 max-w-sm mx-auto">
              {t("home.emptyDesc")}
            </p>
            <div class="flex flex-wrap justify-center gap-3">
              <a
                href="/recipes/new"
                class="inline-flex items-center gap-2 rounded-xl bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/20 hover:brightness-110 transition-all duration-300"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14" /></svg>
                {t("home.addRecipe")}
              </a>
              <a
                href="/users"
                class="inline-flex items-center gap-2 rounded-xl border border-border/50 bg-secondary/50 px-6 py-2.5 text-sm font-medium hover:bg-secondary transition-all duration-200"
              >
                {t("home.browseCommunity")}
              </a>
            </div>
          </section>
        )}

        {/* Cook log strip */}
        {recentLogs.length > 0 && (
          <section class="mb-16">
            <div class="flex items-end justify-between mb-8">
              <h2 class="font-serif text-2xl md:text-3xl tracking-tight">{t("cookLog.title")}</h2>
              <a
                href="/cook-log"
                class="group/link inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.06em] font-medium text-muted-foreground hover:text-primary transition-colors duration-300"
              >
                {t("home.viewAll")}
                <svg class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
            <div class="flex gap-4 overflow-x-auto pb-2 -mx-4 px-4 sm:mx-0 sm:px-0 sm:grid sm:grid-cols-4 sm:overflow-visible">
              {recentLogs.map((log, i) => (
                <a
                  href={`/recipes/${log.recipeSlug}`}
                  class="group shrink-0 w-56 sm:w-auto animate-fade-up"
                  style={`animation-delay: ${i * 50}ms;`}
                >
                  <div class="rounded-2xl bg-card/60 border border-border/30 overflow-hidden transition-all duration-500 hover:border-primary/20 hover:shadow-xl hover:shadow-primary/[0.04] hover:-translate-y-1">
                    {(log.photoUrl || log.recipeImageUrl) ? (
                      <div class="aspect-[4/3] overflow-hidden relative">
                        <img
                          src={(() => {
                            const url = log.photoUrl || log.recipeImageUrl!;
                            return url.startsWith("/") ? `/api/uploads${url}` : url;
                          })()}
                          alt=""
                          class="w-full h-full object-cover transition-all duration-700 group-hover:scale-110"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-card via-card/20 to-transparent opacity-60 pointer-events-none" />
                        {log.rating && (
                          <div class="absolute top-3 right-3 flex items-center gap-0.5">
                            {Array.from({ length: 5 }).map((_, si) => (
                              <span class:list={[
                                "inline-block w-1.5 h-1.5 rounded-full",
                                si < log.rating! ? "bg-primary shadow-sm" : "bg-background/50"
                              ]} />
                            ))}
                          </div>
                        )}
                      </div>
                    ) : (
                      <div class="aspect-[4/3] bg-gradient-to-br from-secondary to-accent/20" />
                    )}
                    <div class="p-3">
                      <h4 class="text-sm font-medium line-clamp-1 group-hover:text-primary transition-colors">{log.recipeTitle}</h4>
                      <time class="text-[11px] text-muted-foreground/50 tabular-nums mt-1 block">{formatDate(log.cookedAt)}</time>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        {/* Community section */}
        {communityRecipes.length > 0 && (
          <section class="mb-16">
            <div class="flex items-end justify-between mb-8">
              <div>
                <h2 class="font-serif text-2xl md:text-3xl tracking-tight">{t("nav.community")}</h2>
                <p class="text-sm text-muted-foreground/50 mt-1">{t("home.communityDesc")}</p>
              </div>
              <a
                href="/users"
                class="group/link inline-flex items-center gap-2 text-[13px] uppercase tracking-[0.06em] font-medium text-muted-foreground hover:text-primary transition-colors duration-300"
              >
                {t("home.allMembers")}
                <svg class="w-4 h-4 transition-transform duration-300 group-hover/link:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
              {communityRecipes.map((recipe, i) => (
                <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms;`}>
                  <a href={`/users/${recipe.createdBy}/recipes/${recipe.slug}`} class="group block">
                    <div class="relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 hover:border-primary/30 hover:shadow-2xl hover:shadow-primary/[0.06] hover:-translate-y-1.5">
                      {recipe.imageUrl ? (
                        <div class="aspect-[4/3] overflow-hidden relative">
                          <img
                            src={recipe.imageUrl.startsWith("/") ? `/api/uploads${recipe.imageUrl}` : recipe.imageUrl}
                            alt={recipe.title}
                            class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-110 group-hover:brightness-110"
                            loading="lazy"
                          />
                          <div class="absolute inset-0 bg-gradient-to-t from-card via-card/20 to-transparent opacity-70 pointer-events-none" />
                          <div class="absolute bottom-0 inset-x-0 p-4 pb-3">
                            <h3 class="font-serif text-xl leading-tight text-foreground line-clamp-2 drop-shadow-lg">
                              {recipe.title}
                            </h3>
                          </div>
                        </div>
                      ) : (
                        <div class="aspect-[4/3] bg-gradient-to-br from-secondary via-muted to-accent/30 flex items-center justify-center relative overflow-hidden">
                          <svg class="w-14 h-14 text-muted-foreground/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
                          </svg>
                          <div class="absolute bottom-0 inset-x-0 p-4 pb-3">
                            <h3 class="font-serif text-xl leading-tight text-foreground/80 line-clamp-2">
                              {recipe.title}
                            </h3>
                          </div>
                        </div>
                      )}
                      <div class="px-4 pb-4 pt-2 flex items-center gap-2">
                        <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 text-[10px] font-semibold text-primary">
                          {recipe.authorName.charAt(0).toUpperCase()}
                        </span>
                        <span class="text-xs text-muted-foreground/60">{recipe.authorName}</span>
                      </div>
                      <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-primary/10" />
                    </div>
                  </a>
                </div>
              ))}
            </div>
          </section>
        )}
      </>
    ) : (
      <>
        {/* ========== LOGGED-OUT LANDING ========== */}

        {/* Hero */}
        <section class="relative pt-20 pb-16 md:pt-28 md:pb-24 text-center overflow-hidden">
          <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-primary/[0.06] blur-[100px] animate-glow-pulse" />
          </div>

          <div class="relative">
            <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-primary/20 bg-primary/5 text-primary text-[13px] font-medium tracking-wide mb-8 animate-fade-in">
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
              </svg>
              {t("home.heroBadge")}
            </div>

            <h1 class="font-serif text-5xl md:text-7xl tracking-tight text-foreground leading-[1.05] animate-fade-up">
              {t("site.title")}
            </h1>
            <p class="text-lg md:text-xl text-muted-foreground mt-5 max-w-md mx-auto leading-relaxed animate-fade-up" style="animation-delay: 80ms;">
              {t("home.heroDesc")}
            </p>

            <div class="flex flex-wrap gap-3 justify-center mt-10 animate-fade-up" style="animation-delay: 160ms;">
              <a
                href="/register"
                class="inline-flex items-center justify-center rounded-xl bg-primary px-8 py-3 text-sm font-semibold text-primary-foreground shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 transition-all duration-300 active:scale-[0.97]"
              >
                {t("home.getStarted")}
              </a>
              <a
                href="/login"
                class="inline-flex items-center gap-2 rounded-xl border border-border bg-secondary/50 backdrop-blur-sm px-8 py-3 text-sm font-semibold hover:bg-secondary hover:border-border/80 transition-all duration-300 active:scale-[0.97]"
              >
                {t("auth.login")}
              </a>
            </div>
          </div>
        </section>

        {/* Stats */}
        <section class="grid grid-cols-3 gap-px mb-20 rounded-2xl overflow-hidden border border-border/30 bg-border/20 animate-fade-up" style="animation-delay: 240ms;">
          {[
            { label: t("nav.recipes"), value: totalRecipes },
            { label: t("home.members"), value: totalMembers },
            { label: t("home.cooked"), value: totalLogs },
          ].map((stat) => (
            <div class="bg-card/60 backdrop-blur-sm p-6 md:p-8 text-center">
              <div class="font-serif text-3xl md:text-4xl text-foreground tracking-tight">{stat.value}</div>
              <div class="text-[11px] uppercase tracking-[0.12em] text-muted-foreground/50 mt-1.5 font-medium">{stat.label}</div>
            </div>
          ))}
        </section>

        {/* Community preview */}
        {communityRecipes.length > 0 && (
          <section class="mb-20">
            <div class="text-center mb-10">
              <h2 class="font-serif text-3xl md:text-4xl tracking-tight">{t("home.whatsCooking")}</h2>
              <p class="text-sm text-muted-foreground/50 mt-2">{t("home.recentCommunity")}</p>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 md:gap-6">
              {communityRecipes.map((recipe, i) => (
                <div class="animate-fade-up" style={`animation-delay: ${i * 60}ms;`}>
                  <div class="relative rounded-2xl bg-card overflow-hidden border border-border/40">
                    {recipe.imageUrl ? (
                      <div class="aspect-[4/3] overflow-hidden relative">
                        <img
                          src={recipe.imageUrl.startsWith("/") ? `/api/uploads${recipe.imageUrl}` : recipe.imageUrl}
                          alt={recipe.title}
                          class="w-full h-full object-cover"
                          loading="lazy"
                        />
                        <div class="absolute inset-0 bg-gradient-to-t from-card via-card/20 to-transparent opacity-70 pointer-events-none" />
                        <div class="absolute bottom-0 inset-x-0 p-4 pb-3">
                          <h3 class="font-serif text-xl leading-tight text-foreground line-clamp-2 drop-shadow-lg">
                            {recipe.title}
                          </h3>
                        </div>
                      </div>
                    ) : (
                      <div class="aspect-[4/3] bg-gradient-to-br from-secondary via-muted to-accent/30 flex items-center justify-center relative overflow-hidden">
                        <svg class="w-14 h-14 text-muted-foreground/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                          <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
                        </svg>
                        <div class="absolute bottom-0 inset-x-0 p-4 pb-3">
                          <h3 class="font-serif text-xl leading-tight text-foreground/80 line-clamp-2">{recipe.title}</h3>
                        </div>
                      </div>
                    )}
                    <div class="px-4 pb-4 pt-2 flex items-center gap-2">
                      <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-primary/10 text-[10px] font-semibold text-primary">
                        {recipe.authorName.charAt(0).toUpperCase()}
                      </span>
                      <span class="text-xs text-muted-foreground/60">{recipe.authorName}</span>
                    </div>
                  </div>
                </div>
              ))}
            </div>
            <div class="text-center mt-10">
              <a
                href="/register"
                class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:underline"
              >
                {t("home.signUpCta")}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
                </svg>
              </a>
            </div>
          </section>
        )}
      </>
    )}

  </div>
</Layout>
