---
import { t } from "../lib/i18n";
import MobileNav from "../islands/MobileNav";
import UserMenu from "../islands/UserMenu";
import ThemeToggle from "../islands/ThemeToggle";

interface Props {
  user?: { id: string; name: string; email: string } | null;
}

const { user } = Astro.props;
const pathname = Astro.url.pathname;

const navLinks = [
  { href: "/recipes", label: t("nav.recipes") },
  { href: "/collections", label: t("nav.collections") },
  { href: "/cook-log", label: t("nav.cookLog") },
];
---

<header
  class="sticky top-0 z-50 border-b border-border/50 bg-background/80 backdrop-blur-2xl backdrop-saturate-150"
>
  <div class="container mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    {/* Logo + nav cluster */}
    <div class="flex items-center gap-10">
      <a
        href="/"
        class="group flex items-center gap-3 transition-all duration-300 hover:opacity-80"
      >
        {/* Amber flame mark */}
        <span
          class="flex items-center justify-center w-9 h-9 rounded-xl bg-primary/15 transition-all duration-300 group-hover:bg-primary/25 group-hover:shadow-lg group-hover:shadow-primary/10"
        >
          <svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
          </svg>
        </span>
        <span class="font-serif text-xl tracking-tight text-foreground">
          Prepped
        </span>
      </a>

      {/* Desktop navigation — understated elegance */}
      <nav class="hidden md:flex items-center gap-1">
        {navLinks.map((link) => {
          const isActive = pathname.startsWith(link.href);
          return (
            <a
              href={link.href}
              class:list={[
                "relative text-[13px] uppercase tracking-[0.08em] px-4 py-2 rounded-lg transition-all duration-200 font-medium",
                isActive
                  ? "text-primary bg-primary/8"
                  : "text-muted-foreground hover:text-foreground hover:bg-secondary/60",
              ]}
            >
              {link.label}
              {/* Subtle underline indicator for active nav */}
              {isActive && (
                <span class="absolute bottom-1 left-4 right-4 h-px bg-gradient-to-r from-transparent via-primary/60 to-transparent" />
              )}
            </a>
          );
        })}
      </nav>
    </div>

    {/* Right side actions */}
    <div class="flex items-center gap-2">
      {user && (
        <a
          href="/recipes/new"
          class="hidden md:inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2 text-[13px] font-semibold text-primary-foreground shadow-lg shadow-primary/20 transition-all duration-200 hover:shadow-xl hover:shadow-primary/30 hover:brightness-110 active:scale-[0.97]"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <path d="M12 5v14M5 12h14" />
          </svg>
          {t("nav.newRecipe")}
        </a>
      )}
      <div class="hidden md:block">
        <ThemeToggle client:load />
      </div>
      <div class="hidden md:block">
        <UserMenu user={user} client:load />
      </div>
      <div class="md:hidden flex items-center gap-1">
        <ThemeToggle client:load />
        <MobileNav user={user} navLinks={navLinks} client:load />
      </div>
    </div>
  </div>
</header>
