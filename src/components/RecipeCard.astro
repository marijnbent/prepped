---
import { t } from "../lib/i18n";
import FavoriteButton from "../islands/FavoriteButton";

interface Props {
  recipe: {
    id: number;
    title: string;
    slug: string;
    description?: string | null;
    imageUrl?: string | null;
    prepTime?: number | null;
    cookTime?: number | null;
    difficulty?: string | null;
  };
  href?: string;
  isFavorited?: boolean;
  showFavorite?: boolean;
}

const { recipe, href, isFavorited = false, showFavorite = false } = Astro.props;
const totalTime = (recipe.prepTime || 0) + (recipe.cookTime || 0);
const link = href || `/recipes/${recipe.slug}`;
---

<a href={link} class="group block">
  <div
    class="card-shine relative rounded-2xl bg-card overflow-hidden border border-border/40 transition-all duration-500 ease-out hover:border-primary/25 hover:shadow-[0_8px_30px_-6px] hover:shadow-primary/[0.08] hover:-translate-y-1"
  >
    {/* Image area */}
    {recipe.imageUrl ? (
      <div class="aspect-[4/3] overflow-hidden relative">
        <img
          src={recipe.imageUrl.startsWith("/") ? `/api/uploads${recipe.imageUrl}` : recipe.imageUrl}
          alt={recipe.title}
          class="w-full h-full object-cover transition-all duration-700 ease-out group-hover:scale-[1.06]"
          loading="lazy"
        />
        {/* Cinematic gradient — darker at bottom for text readability */}
        <div class="absolute inset-0 bg-gradient-to-t from-card via-card/30 to-transparent opacity-80 pointer-events-none" />
        {/* Subtle warm color wash on hover */}
        <div class="absolute inset-0 bg-gradient-to-t from-primary/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none" />
        {/* Title floated over image bottom */}
        <div class="absolute bottom-0 inset-x-0 p-4 pb-3.5">
          <h3 class="font-serif text-xl leading-snug text-foreground line-clamp-2 drop-shadow-[0_1px_2px_rgba(0,0,0,0.1)]">
            {recipe.title}
          </h3>
        </div>
        {/* Favorite button overlay */}
        {showFavorite && (
          <div class="absolute top-3 right-3 z-10">
            <FavoriteButton recipeId={recipe.id} initialFavorited={isFavorited} client:load />
          </div>
        )}
      </div>
    ) : (
      <div class="aspect-[4/3] bg-gradient-to-br from-secondary via-muted/80 to-primary/[0.06] flex items-center justify-center relative overflow-hidden">
        {/* Decorative geometric shapes */}
        <div class="absolute top-6 right-6 w-24 h-24 rounded-full border border-primary/[0.08] animate-float" />
        <div class="absolute bottom-8 left-8 w-16 h-16 rounded-full bg-primary/[0.04]" style="animation-delay: 2s;" />
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-32 h-32 rounded-full bg-primary/[0.03] blur-2xl" />
        <svg class="w-12 h-12 text-muted-foreground/15 transition-all duration-500 group-hover:text-primary/20 group-hover:scale-110" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 12c2-2.96 0-7-1-8 0 3.038-1.773 4.741-3 6-1.226 1.26-2 3.24-2 5a6 6 0 1 0 12 0c0-1.532-1.056-3.94-2-5-1.786 3-2.791 3-4 2z" />
        </svg>
        {/* Title inside empty state */}
        <div class="absolute bottom-0 inset-x-0 p-4 pb-3.5">
          <h3 class="font-serif text-xl leading-snug text-foreground/80 line-clamp-2">
            {recipe.title}
          </h3>
        </div>
        {/* Favorite button overlay */}
        {showFavorite && (
          <div class="absolute top-3 right-3 z-10">
            <FavoriteButton recipeId={recipe.id} initialFavorited={isFavorited} client:load />
          </div>
        )}
      </div>
    )}

    {/* Content area */}
    <div class="px-4 pb-4 pt-2">
      {recipe.description && (
        <p class="text-[13px] text-muted-foreground/70 line-clamp-2 leading-relaxed">
          {recipe.description}
        </p>
      )}
      {(totalTime > 0 || recipe.difficulty) && (
        <div class="flex items-center gap-4 mt-3 pt-3 border-t border-border/20">
          {totalTime > 0 && (
            <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground/60">
              <svg class="w-3.5 h-3.5 text-primary/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" />
              </svg>
              {totalTime} {t("recipe.minutes")}
            </span>
          )}
          {recipe.difficulty && (
            <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground/60 capitalize">
              <span class:list={[
                "w-1.5 h-1.5 rounded-full ring-2",
                recipe.difficulty === "easy" ? "bg-emerald-400 ring-emerald-400/20" :
                recipe.difficulty === "medium" ? "bg-amber-400 ring-amber-400/20" : "bg-rose-400 ring-rose-400/20"
              ]} />
              {t(`recipe.${recipe.difficulty}` as any)}
            </span>
          )}
        </div>
      )}
    </div>

    {/* Ambient glow on hover -- warm ring */}
    <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none ring-1 ring-inset ring-primary/[0.08]" />
  </div>
</a>
